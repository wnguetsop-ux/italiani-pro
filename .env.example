# ============================================================
# ITALIANIPRO — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# ── Firebase (client) ─────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin (serveur — API routes) ─────────────────
# Récupérer dans Firebase Console > Paramètres > Comptes de service
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@italiani-pro.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXX\n-----END PRIVATE KEY-----\n"

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ItalianiPro

# ── AI Providers ──────────────────────────────────────────
# OpenAI (agent principal pour CV, lettres, checklist)
OPENAI_API_KEY=sk-...

# Anthropic Claude (orchestrateur et assistant admin)
ANTHROPIC_API_KEY=sk-ant-...

# ── CinetPay (Mobile Money — MTN, Orange) ─────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_NOTIFY_URL=https://votre-app.vercel.app/api/payments/webhook

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }

    function isAdmin() {
      return userRole() in ['admin', 'super_admin', 'agent', 'coach'];
    }

    function isSuperAdmin() {
      return userRole() in ['admin', 'super_admin'];
    }

    function isOwner(candidateId) {
      return uid() == candidateId;
    }

    function isSponsorOf(candidateId) {
      return exists(/databases/$(database)/documents/sponsor_candidates/$(uid() + '_' + candidateId));
    }

    function canReadCandidate(candidateId) {
      return isOwner(candidateId) || isAdmin() || isSponsorOf(candidateId);
    }

    // ── Users ─────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isAuth() && (uid() == userId || isAdmin());
      allow create: if isAuth() && uid() == userId;
      allow update: if isAuth() && (uid() == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // ── Candidate Profiles ────────────────────────────────
    match /candidate_profiles/{candidateId} {
      allow read:   if isAuth() && canReadCandidate(candidateId);
      allow create: if isAuth() && (uid() == candidateId || isAdmin());
      allow update: if isAuth() && (uid() == candidateId || isAdmin());
      allow delete: if isSuperAdmin();
    }

    // ── Documents ─────────────────────────────────────────
    match /documents/{docId} {
      allow read:  if isAuth() && (
        resource.data.candidate_id == uid() || isAdmin()
      );
      allow create: if isAuth() && (
        request.resource.data.candidate_id == uid() || isAdmin()
      );
      allow update: if isAuth() && (
        // Candidat peut uploader une nouvelle version
        (resource.data.candidate_id == uid() && request.resource.data.status == 'uploaded')
        // Admin peut changer le statut
        || isAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── Orders ────────────────────────────────────────────
    match /orders/{orderId} {
      allow read:  if isAuth() && (resource.data.candidate_id == uid() || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Payments ──────────────────────────────────────────
    match /payments/{paymentId} {
      allow read:  if isAuth() && (resource.data.candidate_id == uid() || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false; // Jamais supprimer un paiement
    }

    // ── Milestones ────────────────────────────────────────
    match /milestones/{milestoneId} {
      allow read:  if isAuth() && isAdmin();
      allow read:  if isAuth() && resource.data.candidate_id == uid() && resource.data.is_unlocked == true;
      allow write: if isAdmin();
    }

    // ── Conversations ─────────────────────────────────────
    match /conversations/{convId} {
      allow read:  if isAuth() && (resource.data.candidateId == uid() || isAdmin());
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.candidateId == uid() || isAdmin());

      // Messages — sous-collection
      match /messages/{msgId} {
        // Candidat voit ses messages approuvés et non-internes
        allow read:  if isAuth() && (
          (resource.data.candidateId == uid() && resource.data.approved == true && resource.data.isInternal == false)
          || isAdmin()
        );
        // Candidat peut créer des messages (sender=client)
        allow create: if isAuth() && (
          (request.resource.data.sender == 'client' && request.resource.data.candidateId == uid())
          || isAdmin()
        );
        // Seuls les admins peuvent modifier (ex: approuver)
        allow update: if isAdmin();
        allow delete: if isSuperAdmin();
      }
    }

    // ── Notifications ─────────────────────────────────────
    match /notifications/{notifId} {
      allow read:  if isAuth() && resource.data.user_id == uid();
      allow update: if isAuth() && resource.data.user_id == uid()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read']);
      allow create: if isAdmin();
      allow delete: if isAuth() && resource.data.user_id == uid();
    }

    // ── AI Events — admin seulement ───────────────────────
    match /aiEvents/{eventId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── AI Runs — admin seulement ─────────────────────────
    match /aiRuns/{runId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Proofs ────────────────────────────────────────────
    match /proofs/{proofId} {
      // Candidat peut voir ses preuves validées
      allow read:  if isAuth() && (
        (resource.data.candidate_id == uid() && resource.data.status == 'validated')
        || isAdmin()
      );
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Proof Files ───────────────────────────────────────
    match /proof_files/{fileId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── CV Versions ───────────────────────────────────────
    match /cv_versions/{cvId} {
      allow read:  if isAuth() && (resource.data.candidate_id == uid() || isAdmin());
      allow write: if isAdmin();
    }

    // ── Cover Letters ─────────────────────────────────────
    match /cover_letters/{letterId} {
      allow read:  if isAuth() && (resource.data.candidate_id == uid() || isAdmin());
      allow write: if isAdmin();
    }

    // ── Internal Notes — admin only ───────────────────────
    match /internal_notes/{noteId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Admin Tasks ───────────────────────────────────────
    match /adminTasks/{taskId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Activity Logs ─────────────────────────────────────
    match /activity_logs/{logId} {
      allow read:  if isAdmin();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }

    // ── Appointments ──────────────────────────────────────
    match /appointments/{apptId} {
      allow read:  if isAuth() && (resource.data.candidate_id == uid() || isAdmin());
      allow write: if isAdmin();
    }

    // ── Packages — lecture publique ───────────────────────
    match /packages/{packId} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    // ── Flussi Events — lecture publique ──────────────────
    match /flussi_events/{eventId} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    // ── Knowledge Articles ────────────────────────────────
    match /knowledge_articles/{artId} {
      allow read:  if isAuth() || resource.data.is_published == true;
      allow write: if isSuperAdmin();
    }

    // ── Promo Codes ───────────────────────────────────────
    match /promo_codes/{promoId} {
      allow read:  if isAdmin();
      allow write: if isSuperAdmin();
    }

    // ── Invoices ─────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read:  if isAuth() && (resource.data.candidate_id == uid() || isAdmin());
      allow write: if isAdmin();
    }

    // ── Sponsors ─────────────────────────────────────────
    match /sponsors/{sponsorId} {
      allow read:  if isAuth() && (uid() == sponsorId || isAdmin());
      allow write: if isAuth() && (uid() == sponsorId || isAdmin());
    }

    match /sponsor_candidates/{linkId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Support Tickets ───────────────────────────────────
    match /support_tickets/{ticketId} {
      allow read:  if isAuth() && (resource.data.user_id == uid() || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    match /ticket_replies/{replyId} {
      allow read:  if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    // ── Referrals ─────────────────────────────────────────
    match /referrals/{refId} {
      allow read:  if isAuth() && (resource.data.referrer_id == uid() || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
    }
  }
}
